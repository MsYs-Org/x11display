CH347_CLOCK=1
CAPTURE=xdamage
XCAP_IDLE_FPS=0
# Runtime FPS cap is stored separately in ch347/fps.env by scripts/set_fps.sh.
XCAP_DEBUG=0
XCAP_OUTPUT=frame
PACKET_US=0
PIXFMT=rgb565be
FPS=30
MAX_FRAMES=0
DEPTH=8
WINDOW_EACH_FRAME=0
DRAIN_US=0
ACK_READS=0
DEBUG=0
CH347_DEBUG_OVERLAY=0
CH347_DEBUG_OVERLAY_ALPHA=176
CH347_DEBUG_OVERLAY_SCALE=1
CH347_DEBUG_OVERLAY_ITEMS=fps,dirty,bytes
CH347_DEBUG_OVERLAY_INTERVAL_MS=1000
GATED=0
RENDER_MS=30
# MSYS owns application/window policy; keep standalone demo processes disabled.
APP=none
WM=none
DISPLAY_ID=:24
XSERVER=Xorg
XORG_CONFIG=/root/x11display/xorg/xorg.conf
WIDTH=320
HEIGHT=480

# Dirty renderer defaults. These can be tuned without changing the stable base.
CH347_FULL_AREA_PCT=40
CH347_MAX_RECTS=1
CH347_STALE_MS=0
CH347_STALE_BUDGET=60
CH347_HOLD_CS=1
CH347_LATEST_ONLY=1
CH347_URB_TIMEOUT_MS=1500
CH347_GPIO_OVERLAY=0
CH347_GPIO_OVERLAY_MS=200
CH347_RESTART_ON_FAIL=1
CH347_RESTART_DELAY_SEC=2
# Keep the X11 session alive through an arbitrarily long cable/USB outage.
# Positive limits are reserved for explicit bench diagnostics.
CH347_RESTART_MAX=0

# XPT2046 resistive touch on the same SPI bus. Disabled until the wiring is in.
CH347_TOUCH=0
CH347_TOUCH_USE_IRQ=0
# touch: direct finger semantics with no persistent cursor; mouse: legacy pointer mode.
CH347_TOUCH_MODE=touch
CH347_TOUCH_MODE_FILE=/tmp/ch347_dirty_usb_x11/touch_mode
CH347_CURSOR=1
CH347_TOUCH_CALIBRATE=0
CH347_TOUCH_CAL_FILE=/root/x11display/ch347/touch_calibration.env
CH347_TOUCH_CAL_EXIT=1
CH347_TOUCH_CAL_MARGIN=32
CH347_TOUCH_POLL_MS=32
CH347_TOUCH_SWAP_XY=0
CH347_TOUCH_INVERT_X=0
CH347_TOUCH_INVERT_Y=0
CH347_TOUCH_X_MIN=200
CH347_TOUCH_X_MAX=3900
CH347_TOUCH_Y_MIN=200
CH347_TOUCH_Y_MAX=3900
CH347_TOUCH_WIDTH=320
CH347_TOUCH_HEIGHT=480
CH347_TOUCH_MOVE_THRESH=2
CH347_TOUCH_JUMP_THRESH=160
CH347_TOUCH_FILTER_WEIGHT=1
CH347_TOUCH_MAX_ERRORS=8
CH347_TOUCH_CLOCK=5
CH347_TOUCH_RELEASE_SAMPLES=3
CH347_TOUCH_CAL_SAMPLES=4
CH347_TOUCH_Z_MIN=50
CH347_TOUCH_PRESSURE_MIN=50
CH347_TOUCH_Z_STRICT=1
CH347_TOUCH_DEBUG=0
CH347_TOUCH_DISABLE_ON_ERRORS=0
